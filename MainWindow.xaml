<Window x:Class="are_you_there.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADHD Focus Audio" Height="450" Width="600" Background="#F4F4F4">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">

            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Padding="10" Margin="0,0,0,20">
                <TextBlock x:Name="StatusText" Text="상태: 대기 중 ⚪" FontSize="18" FontWeight="Bold" Foreground="#555555" HorizontalAlignment="Center"/>
            </Border>

            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="집중 시 볼륨 (%)" Foreground="Black" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <Slider x:Name="FocusedSlider" Minimum="0" Maximum="100" Value="100" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBox Grid.Column="1" Text="{Binding ElementName=FocusedSlider, Path=Value, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14" FontWeight="Bold"/>
                </Grid>

                <TextBlock Text="비집중 시 볼륨 (%)" Foreground="Black" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>

                    <Slider x:Name="UnfocusedSlider" Minimum="0" Maximum="100" Value="10" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBox Grid.Column="1" Text="{Binding ElementName=UnfocusedSlider, Path=Value, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0}}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="14" FontWeight="Bold"/>
                </Grid>

                <Button Content="설정 적용" Click="ApplyButton_Click" Height="40" Background="#E0E0E0" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="StartButton" Content="Start" Click="StartButton_Click" Height="50" Width="120" Margin="0,0,20,0" Background="#4CAF50" Foreground="White" FontSize="22" FontWeight="Bold"/>
                <Button x:Name="EndButton" Content="Stop" Click="EndButton_Click" Height="50" Width="120" Background="#F44336" Foreground="White" FontSize="22" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>